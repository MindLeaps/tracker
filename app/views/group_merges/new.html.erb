<% content_for :title, 'Merge groups' %>

<%= render LayoutComponents::HeaderComponent.new(current_user: current_user, tabs: [
  { title: 'Merge groups', href: '' }
]) %>

<div class="max-w-4xl p-4">
  <%= render CommonComponents::Card.new(title: 'Choose merge direction') do |card| %>
    <% card.with_card_content do %>
      <div class="bg-white p-6">
        <%= form_with scope: :group_merge, url: preview_group_merge_path, class: 'space-y-6' do |f| %>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div>
              <%= f.label :destination_group_id, 'Destination group', class: 'field-label' %>
              <%= f.collection_select :destination_group_id, @destination_groups, :id, :chapter_group_name_with_full_mlid,
                                      { selected: @destination_group&.id, include_blank: true },
                                      class: 'mt-1 block w-full rounded-md border-gray-300 shadow-xs focus:border-green-600 focus:ring-green-600 sm:text-sm' %>
              <p class="mt-2 text-sm text-gray-500">This group remains active after the merge.</p>
            </div>

            <div>
              <%= f.label :source_group_id, 'Source group', class: 'field-label' %>
              <%= f.collection_select :source_group_id, @source_groups, :id, :chapter_group_name_with_full_mlid,
                                      { include_blank: true },
                                      class: 'mt-1 block w-full rounded-md border-gray-300 shadow-xs focus:border-green-600 focus:ring-green-600 sm:text-sm' %>
              <p class="mt-2 text-sm text-gray-500">This group will be deleted if the merge is confirmed later.</p>
            </div>
          </div>

          <%= f.submit 'Preview merge', class: 'normal-button' %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
