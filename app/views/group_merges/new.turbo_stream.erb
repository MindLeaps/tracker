<%= turbo_stream.replace 'modal' do %>
  <div id="modal" class="relative z-10" aria-labelledby="merge-groups-modal-title" role="dialog" aria-modal="true" data-controller="modal">
    <div class="fixed inset-0 bg-gray-500/50 transition-opacity backdrop-out transform-gpu" data-modal-target="backdrop"></div>
    <div class="fixed inset-0 z-10 w-screen overflow-y-auto" data-action="click->modal#close">
      <div class="flex min-h-full items-end justify-center p-4 sm:items-center sm:p-0">
        <div class="modal-out transition-all transform-gpu" data-modal-target="modal" data-action="click->modal#stopPropagation">
          <%= render CommonComponents::Card.new(title: 'Merge groups') do |card| %>
            <% card.with_card_content do %>
              <div class="bg-white w-full max-w-3xl p-6">
                <%= form_with scope: :group_merge, url: preview_group_merge_path, class: 'space-y-6' do |f| %>
                  <div class="rounded-md border border-red-200 bg-red-50 p-4">
                    <div id="merge-groups-modal-title" class="text-sm font-semibold text-red-900">This action is destructive</div>
                    <p class="mt-2 text-sm leading-6 text-red-800">
                      The source group will be deleted after its lessons, grades, and enrollments are merged into the destination group.
                    </p>
                  </div>

                  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                    <div>
                      <%= f.label :destination_group_id, 'Destination group', class: 'field-label' %>
                      <%= f.collection_select :destination_group_id, @destination_groups, :id, :chapter_group_name_with_full_mlid,
                                              { selected: @destination_group&.id, include_blank: true },
                                              class: 'mt-1 block w-full rounded-md border-gray-300 shadow-xs focus:border-green-600 focus:ring-green-600 sm:text-sm' %>
                      <p class="mt-2 text-sm text-gray-500">This group remains active after the merge.</p>
                    </div>

                    <div>
                      <%= f.label :source_group_id, 'Source group', class: 'field-label' %>
                      <%= f.collection_select :source_group_id, @source_groups, :id, :chapter_group_name_with_full_mlid,
                                              { include_blank: true },
                                              class: 'mt-1 block w-full rounded-md border-gray-300 shadow-xs focus:border-green-600 focus:ring-green-600 sm:text-sm' %>
                      <p class="mt-2 text-sm text-gray-500">This group will be deleted after confirmation.</p>
                    </div>
                  </div>

                  <div class="flex gap-3">
                    <%= f.submit 'Preview merge', class: 'button normal-button' %>
                    <div class="dangerous-button" data-action="click->modal#close"><%= t(:cancel) %></div>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
<%= turbo_stream.update('flashes', partial: 'shared/flashes') %>
