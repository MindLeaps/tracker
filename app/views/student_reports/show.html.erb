<%
  @components = [
    { id: 'studentAverages', name: 'Student Averages' },
    { id: 'performanceChanges', name: 'Performance Changes' },
    { id: 'skillAverages', name: 'Skill Averages' },
  ]
%>

<div class="w-full print:overflow-visible overflow-x-hidden">
  <section class="w-full print:hidden">
    <%= render CommonComponents::Card.new(title: t(:report_controls)) do |card| %>
      <% card.with_card_content do %>
        <div class="w-full bg-white p-4 flex gap-12 items-center justify-center">
            <% @components.each do |c| %>
              <%= render CommonComponents::ToggleComponent.new(id: "#{c[:id]}Toggle", text: c[:name]) %>
            <% end %>
        </div>
      <% end %>
    <% end %>
  </section>

  <h1 class="text-3xl mb-2 font-bold tracking-tight text-center text-gray-900 sm:text-4xl print:text-2xl">Student Report - <%=@student.proper_name%></h1>

  <section id="studentAverages" class="w-full px-2 pagebreak-after">
    <%= render CommonComponents::Card.new(title: t(:student_averages)) do |card| %>
      <% card.with_card_content do %>
        <div id="student-history-chart" class="ct-chart ct-octave bg-white"></div>
      <% end %>
    <% end %>
  </section>

  <% unless @performance_changes.empty? %>
    <section id="performanceChanges" class="w-full px-2 print:px-0 print:mb-4 pagebreak-after">
      <%= render CommonComponents::Card.new(title: t(:performance_change)) do |card| %>
        <% card.with_card_content do %>
          <div class="space-y-4 print:space-y-3">
            <% @performance_changes.each do |performance_change| %>
              <% first_to_middle_diff = performance_change[:first_to_middle_diff].to_f %>
              <% middle_to_last_diff = performance_change[:middle_to_last_diff].to_f %>
              <% overall_diff = performance_change[:overall_diff].to_f %>

              <div class="print-avoid-break overflow-hidden rounded-2xl border border-gray-200 bg-gray-100 px-6 py-6 shadow-sm print:rounded-xl print:px-4 print:py-4">
                <div class="mb-4 flex items-center justify-between">
                  <div>
                    <h3 class="text-lg font-bold tracking-tight text-gray-900">
                      <%= performance_change[:subject_name] %>
                    </h3>
                    <p class="text-sm text-gray-500">
                      Based on <%= performance_change[:lesson_count] %> lessons
                    </p>
                  </div>

                  <div class="text-right">
                    <p class="text-sm font-medium text-gray-500">Overall Change</p>
                    <p class="text-xl font-bold <%= overall_diff >= 0 ? 'text-green-700' : 'text-red-700' %>">
                      <%= overall_diff >= 0 ? '▲' : '▼' %>
                      <%= overall_diff >= 0 ? '+' : '' %><%= performance_change[:overall_diff] %>
                    </p>
                  </div>
                </div>

                <div class="grid grid-cols-1 gap-4 md:grid-cols-3 print:grid-cols-3 print:gap-3">
                  <div class="rounded-xl border border-gray-200 bg-white p-5">
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 print:text-[10px]">
                      Start Point
                    </p>
                    <p class="mt-2 text-sm text-gray-500 print:text-[11px]">
                      <%= performance_change[:first_date] %>
                    </p>
                    <p class="mt-3 text-4xl font-bold tracking-tight text-gray-900 print:mt-2 print:text-2xl">
                      <%= performance_change[:first_avg] %>
                    </p>
                  </div>

                  <div class="rounded-xl border border-gray-200 bg-white p-5">
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 print:text-[10px]">
                      Middle Point
                    </p>
                    <p class="mt-2 text-sm text-gray-500 print:text-[11px]">
                      <%= performance_change[:middle_date] %>
                    </p>
                    <p class="mt-3 text-4xl font-bold tracking-tight text-gray-900 print:mt-2 print:text-2xl">
                      <%= performance_change[:middle_avg] %>
                    </p>
                    <p class="mt-3 text-lg font-semibold <%= first_to_middle_diff >= 0 ? 'text-green-600' : 'text-red-600' %> print:mt-2 print:text-sm">
                      <%= first_to_middle_diff >= 0 ? '▲' : '▼' %>
                      <%= first_to_middle_diff >= 0 ? '+' : '' %><%= performance_change[:first_to_middle_diff] %>
                      <span class="ml-1 text-sm font-medium text-gray-500 print:text-[10px]">
                      from start
                    </span>
                    </p>
                  </div>

                  <div class="rounded-xl border border-gray-200 bg-white p-5">
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 print:text-[10px]">
                      Latest Point
                    </p>
                    <p class="mt-2 text-sm text-gray-500 print:text-[11px]">
                      <%= performance_change[:last_date] %>
                    </p>
                    <p class="mt-3 text-4xl font-bold tracking-tight text-gray-900 print:mt-2 print:text-2xl">
                      <%= performance_change[:last_avg] %>
                    </p>
                    <p class="mt-3 text-lg font-semibold <%= middle_to_last_diff >= 0 ? 'text-green-600' : 'text-red-600' %> print:mt-2 print:text-sm">
                      <%= middle_to_last_diff >= 0 ? '▲' : '▼' %>
                      <%= middle_to_last_diff >= 0 ? '+' : '' %><%= performance_change[:middle_to_last_diff] %>
                      <span class="ml-1 text-sm font-medium text-gray-500 print:text-[10px]">
                      from middle
                    </span>
                    </p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </section>
  <% end %>

  <section id="skillAverages" class="w-full px-2 print:px-0 pagebreak-after">
    <%= render CommonComponents::Card.new(title: t(:skill_averages)) do |card| %>
      <% card.with_card_content do %>
        <div class="space-y-4 print:space-y-3">
          <% @student_skill_averages.each do |subject_name, summary| %>
            <div class="print-avoid-break overflow-hidden rounded-2xl border border-gray-200 bg-gray-100 px-6 py-6 shadow-sm print:rounded-xl print:px-4 print:py-4">
              <div class="mb-4 print:mb-3">
                <h3 class="text-xl font-bold tracking-tight text-gray-900 print:text-lg">
                  <%= subject_name %> Skill Averages
                </h3>
              </div>

              <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 print:grid-cols-4 print:gap-2">
                <% summary[:skills].each do |row| %>
                  <% is_strongest = row[:skill] == summary[:strongest][:skill] %>
                  <% is_weakest = row[:skill] == summary[:weakest][:skill] %>

                  <% card_classes =
                       if is_strongest
                         "border-green-200 bg-green-50"
                       elsif is_weakest
                         "border-red-200 bg-red-50"
                       else
                         "border-gray-200 bg-white"
                       end
                  %>

                  <% label_classes =
                       if is_strongest
                         "text-green-700"
                       elsif is_weakest
                         "text-red-700"
                       else
                         "text-gray-500"
                       end
                  %>

                  <div class="rounded-xl border px-4 py-4 shadow-sm print:rounded-lg print:px-3 print:py-3 <%= card_classes %>">
                    <% if is_strongest %>
                      <p class="text-xs font-semibold uppercase tracking-wide <%= label_classes %> print:text-[10px]">
                        Top Rated
                      </p>
                    <% elsif is_weakest %>
                      <p class="text-xs font-semibold uppercase tracking-wide <%= label_classes %> print:text-[10px]">
                        Lowest Rated
                      </p>
                    <% end %>

                    <p class="mt-1 text-base font-semibold leading-snug text-gray-900 print:text-sm">
                      <%= row[:skill] %>
                    </p>

                    <p class="mt-3 text-3xl font-bold tracking-tight text-gray-900 print:mt-2 print:text-xl">
                      <%= row[:average] %>
                    </p>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </section>
</div>

<script>
  window.onChartsLoad = function () {
    let groupedSummaries = <%= @grouped_student_summaries.to_json.html_safe %>;

    displayStudentReportPerformanceByGroupChart && displayStudentReportPerformanceByGroupChart("#student-history-chart", groupedSummaries, { title: "Student performance by lesson and group", heightPx: 100 })
  }
</script>
<%= javascript_include_tag "new_charts", onload: 'window.onChartsLoad && window.onChartsLoad()' %>